{
  "name": "cross-app-qa-agent",
  "version": "0.1.0",
  "description": "Standalone distributable QA agent that adapts a Playwright test suite to any seller/ecomm web app via an AppProfile abstraction, a startup wizard, and an LLM-backed adaptation step.",
  "type": "module",
  "scripts": {
    "adapt-app": "tsx scripts/adapt-app.ts",
    "adapt-app-agent": "tsx scripts/adapt-app-agent.ts",
    "propose-heal-updates": "tsx scripts/propose-heal-updates.ts",
    "port-from-source": "tsx scripts/port-from-source.ts",
    "test:ui": "playwright test",
    "test:ui:headed": "playwright test --headed",
    "test:ui:report": "playwright show-report reports/playwright-html"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18"
  }
}
