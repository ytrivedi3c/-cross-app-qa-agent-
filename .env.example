# ─── REQUIRED ────────────────────────────────────────────────────────────────

# Which app profile to activate at runtime.
# Must match a file at tests/ui/config/app-profiles/<APP_PROFILE>.ts.
APP_PROFILE=example

# Claude API key (used by the adaptation agent + heal-proposal script).
# Not needed at test runtime — only when adapting a new app or proposing heals.
ANTHROPIC_API_KEY=

# ─── AUTH TOKEN (name depends on your profile) ───────────────────────────────
# Each AppProfile declares which env var holds the JWT/access token.
# Set ONLY the one your profile uses.
# Examples:
#   SELLER_ACCESS_TOKEN=
#   XYZ_TOKEN=

# ─── OPTIONAL ────────────────────────────────────────────────────────────────

# Override base URL (otherwise uses profile.auth.loginPathPattern + default host).
# APP_BASE_URL=

# For Layer 6 sync tooling (only matters when porting from QA-automation).
# QA_AUTOMATION_PATH=/home/you/QA-automation
